{
  "name": "MicroAPI Monorepo",
  "dockerComposeFile": "../infrastructure/docker/docker-compose.yml",
  "service": "api-gateway",
  "workspaceFolder": "/app",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=2560",
    "HUSKY": "0"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "mongodb.mongodb-vscode"
      ]
    }
  },
  "forwardPorts": [5000, 5001, 5002, 5003, 6379, 27017],
  "onCreateCommand": "corepack enable && pnpm install --child-concurrency 1 --prefer-offline",
  "postCreateCommand": "pnpm --filter @repo/shared build && echo 'Codespace ready! Services are starting in the background.'",
  "remoteUser": "node"
}
