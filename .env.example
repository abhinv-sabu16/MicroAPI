# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-to-a-256-bit-random-secret-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d

# ─── CORS ─────────────────────────────────────────────────────
# Leave empty in dev (all origins allowed).
# Production: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ─── Ports ────────────────────────────────────────────────────
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
NOTIFICATION_SERVICE_PORT=5003
NGINX_PORT=80

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gateway_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gateway_db

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ─── Rate Limiting (Day 8) ────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Kafka (Day 11) ───────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=api-gateway
KAFKA_GROUP_ID=api-gateway-group

# ─── Observability (Day 13+) ──────────────────────────────────
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
